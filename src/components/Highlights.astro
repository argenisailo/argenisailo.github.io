---
import { siteConfig } from "../config";
const hasHighlights = siteConfig.highlights && siteConfig.highlights.length > 0;
---

{hasHighlights && (
  <section id="highlights" class="py-20 sm:py-24 px-8 sm:px-12 lg:px-24 border-b border-border">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-start">

        <div>
          <h2 class="font-display font-semibold text-2xl sm:text-3xl text-foreground tracking-tight">
            <span data-lang="en">Highlights</span>
            <span data-lang="es">Logros</span>
          </h2>
          <div class="mt-3 h-px w-10 bg-primary"></div>
        </div>

        <div class="divide-y divide-border">
          {siteConfig.highlights.map((high, i) => {
            const esHigh = siteConfig.es.highlights[i];
            return (
              <div class="py-8 first:pt-0">
                <h3 class="font-semibold text-foreground leading-snug">
                  <span data-lang="en">{high.achievement}</span>
                  <span data-lang="es">{esHigh.achievement}</span>
                </h3>
                <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
                  <span data-lang="en">{high.description}</span>
                  <span data-lang="es">{esHigh.description}</span>
                </p>
              </div>
            );
          })}
        </div>

      </div>
    </div>
  </section>
)}
