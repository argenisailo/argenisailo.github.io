---
import { siteConfig } from "../config";

const hasApproach = siteConfig.approach && siteConfig.approach.length > 0;
const hasHighlights = siteConfig.highlights && siteConfig.highlights.length > 0;
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;
const hasTechnologies = siteConfig.technologies && siteConfig.technologies.length > 0;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 hidden md:block transition-all duration-300"
>
  <nav class="max-w-6xl mx-auto px-8 lg:px-12 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li>
        <a href="#about" class="font-mono text-xs uppercase tracking-widest text-white/40 hover:text-white transition-colors duration-200">
          <span data-lang="en">About</span>
          <span data-lang="es">Sobre mí</span>
        </a>
      </li>
      {hasApproach && (
        <li>
          <a href="#approach" class="font-mono text-xs uppercase tracking-widest text-white/40 hover:text-white transition-colors duration-200">
            <span data-lang="en">Approach</span>
            <span data-lang="es">Enfoque</span>
          </a>
        </li>
      )}
      {hasHighlights && (
        <li>
          <a href="#highlights" class="font-mono text-xs uppercase tracking-widest text-white/40 hover:text-white transition-colors duration-200">
            <span data-lang="en">Highlights</span>
            <span data-lang="es">Logros</span>
          </a>
        </li>
      )}
      {hasExperience && (
        <li>
          <a href="#experience" class="font-mono text-xs uppercase tracking-widest text-white/40 hover:text-white transition-colors duration-200">
            <span data-lang="en">Experience</span>
            <span data-lang="es">Experiencia</span>
          </a>
        </li>
      )}
      {hasProjects && (
        <li>
          <a href="#projects" class="font-mono text-xs uppercase tracking-widest text-white/40 hover:text-white transition-colors duration-200">
            <span data-lang="en">Projects</span>
            <span data-lang="es">Proyectos</span>
          </a>
        </li>
      )}
      {hasEducation && (
        <li>
          <a href="#education" class="font-mono text-xs uppercase tracking-widest text-white/40 hover:text-white transition-colors duration-200">
            <span data-lang="en">Education</span>
            <span data-lang="es">Formación</span>
          </a>
        </li>
      )}
      {hasCertifications && (
        <li>
          <a href="#certifications" class="font-mono text-xs uppercase tracking-widest text-white/40 hover:text-white transition-colors duration-200">
            Certs
          </a>
        </li>
      )}
      {hasTechnologies && (
        <li>
          <a href="#technologies" class="font-mono text-xs uppercase tracking-widest text-white/40 hover:text-white transition-colors duration-200">
            Stack
          </a>
        </li>
      )}
      <li>
        <button
          id="lang-toggle"
          class="font-mono text-xs uppercase tracking-widest transition-colors duration-200 flex items-center gap-1 cursor-pointer"
          aria-label="Toggle language"
        >
          <span id="lang-toggle-en">EN</span>
          <span style="color: rgb(255 255 255 / 0.15)">/</span>
          <span id="lang-toggle-es">ES</span>
        </button>
      </li>
    </ul>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (!header) return;
    if (window.scrollY > 80) {
      header.classList.add("bg-hero");
      header.style.borderBottom = "1px solid rgba(255,255,255,0.06)";
    } else {
      header.classList.remove("bg-hero");
      header.style.borderBottom = "";
    }
  });

  document.getElementById("lang-toggle")?.addEventListener("click", () => {
    const isEs = document.documentElement.classList.toggle("lang-es");
    try { localStorage.setItem("lang", isEs ? "es" : "en"); } catch(e) {}
  });
</script>
