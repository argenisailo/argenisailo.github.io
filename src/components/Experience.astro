---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{hasExperience && (
  <section id="experience" class="py-20 sm:py-24 px-8 sm:px-12 lg:px-24 border-b border-border">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-start">

        <div>
          <h2 class="font-display font-semibold text-2xl sm:text-3xl text-foreground tracking-tight">
            Experience
          </h2>
          <div class="mt-3 h-px w-10 bg-primary"></div>
        </div>

        <div class="divide-y divide-border">
          {siteConfig.experience.map((exp) => (
            <div class="py-8 first:pt-0">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-4">
                <div>
                  <h3 class="font-display font-semibold text-lg text-foreground tracking-tight">
                    {exp.title}
                  </h3>
                  <span class="font-mono text-xs uppercase tracking-widest text-primary mt-0.5 block">
                    {exp.company}
                  </span>
                </div>
                <span class="font-mono text-xs text-muted-foreground shrink-0 sm:text-right">
                  {exp.dateRange}
                </span>
              </div>

              {exp.summary && (
                <p class="mb-4 text-sm text-muted-foreground leading-relaxed">{exp.summary}</p>
              )}

              <ul class="space-y-2.5">
                {exp.bullets.map((bullet) => (
                  <li class="flex gap-3 text-sm text-muted-foreground leading-relaxed">
                    <span class="text-primary mt-1 shrink-0 leading-none">·</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
)}
