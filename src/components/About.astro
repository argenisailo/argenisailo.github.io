---
import { siteConfig } from "../config";
---

<section id="about" class="py-20 sm:py-24 px-8 sm:px-12 lg:px-24 border-b border-border">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-start">

      <div>
        <h2 class="font-display font-semibold text-2xl sm:text-3xl text-foreground tracking-tight">
          <span data-lang="en">About</span>
          <span data-lang="es">Sobre mí</span>
        </h2>
        <div class="mt-3 h-px w-10 bg-primary"></div>
      </div>

      <div>
        <p class="text-base sm:text-lg text-muted-foreground leading-relaxed">
          <span data-lang="en">{siteConfig.aboutMe}</span>
          <span data-lang="es">{siteConfig.es.aboutMe}</span>
        </p>

        <div class="mt-8 pt-8 border-t border-border">
          <span class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
            <span data-lang="en">Focus areas</span>
            <span data-lang="es">Áreas de foco</span>
          </span>
          <p class="mt-3 text-sm text-muted-foreground leading-relaxed">
            <span data-lang="en">{siteConfig.skills.join(" · ")}</span>
            <span data-lang="es">{siteConfig.es.skills.join(" · ")}</span>
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
