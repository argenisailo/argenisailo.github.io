---
import { siteConfig } from "../config";
const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;
---

{hasCertifications && (
  <section id="certifications" class="py-20 sm:py-24 px-8 sm:px-12 lg:px-24 border-b border-border">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-start">

        <div>
          <h2 class="font-display font-semibold text-2xl sm:text-3xl text-foreground tracking-tight">
            <span data-lang="en">Certifications</span>
            <span data-lang="es">Certificaciones</span>
          </h2>
          <div class="mt-3 h-px w-10 bg-primary"></div>
        </div>

        <div class="divide-y divide-border">
          {siteConfig.certifications.map((cert) => (
            <div class="py-8 first:pt-0">
              <span class="font-mono text-xs uppercase tracking-widest text-primary">
                {cert.school}
              </span>
              <h3 class="mt-1 font-semibold text-foreground">
                {cert.name}
              </h3>
              <p class="mt-2 text-sm text-muted-foreground">
                {cert.description.join(" · ")}
              </p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
)}
