---
import { siteConfig } from "../config";
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center px-8 sm:px-12 lg:px-24"
  style="background-color: var(--hero-bg);"
>
  <div class="max-w-3xl">
    <!-- Name -->
    <h1 class="font-display font-bold text-5xl sm:text-6xl lg:text-7xl xl:text-8xl tracking-tight text-white animate-reveal">
      {siteConfig.name}
    </h1>

    <!-- The arista hairline — shared DNA with punto-arista.com -->
    <div class="my-4 sm:my-5 h-px w-full animate-reveal animate-delay-150" style="background-color: var(--primary);"></div>

    <!-- Role -->
    <p class="font-mono text-sm sm:text-base text-white/60 tracking-wide leading-relaxed animate-reveal animate-delay-150">
      {siteConfig.title}
    </p>

    <!-- Tagline -->
    <p class="mt-8 text-base sm:text-lg text-white/40 leading-relaxed max-w-xl animate-reveal animate-delay-300">
      Translates client pain points into scalable solutions — building custom software,
      configuring platforms, or challenging the initial ask when a better path exists.
    </p>

    <!-- Social links -->
    <div class="mt-10 flex items-center gap-5 animate-reveal animate-delay-450">
      {siteConfig.social?.linkedin && (
        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-white/40 hover:text-white transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <path d="M8 11v5"/><path d="M8 8v.01"/>
            <path d="M12 16v-5"/>
            <path d="M16 16v-3a2 2 0 1 0 -4 0"/>
            <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z"/>
          </svg>
        </a>
      )}
      {siteConfig.social?.github && (
        <a
          href={siteConfig.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-white/40 hover:text-white transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"/>
          </svg>
        </a>
      )}
      {siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          aria-label="Email"
          class="text-white/40 hover:text-white transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/>
            <path d="M3 7l9 6l9 -6"/>
          </svg>
        </a>
      )}
      {siteConfig.social?.website && (
        <a
          href={siteConfig.social.website}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="punto-arista.com"
          class="font-mono text-xs text-white/30 hover:text-white/60 transition-colors duration-200 tracking-wide"
        >
          punto-arista.com ↗
        </a>
      )}
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-8 sm:left-12 lg:left-24">
    <span class="font-mono text-xs text-white/20 tracking-widest uppercase">Scroll</span>
  </div>
</section>
