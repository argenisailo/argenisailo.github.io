---
import { siteConfig } from "../config";
const hasTechnologies = siteConfig.technologies && siteConfig.technologies.length > 0;
---

{hasTechnologies && (
  <section id="technologies" class="py-20 sm:py-24 px-8 sm:px-12 lg:px-24 border-b border-border">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-start">

        <div>
          <h2 class="font-display font-semibold text-2xl sm:text-3xl text-foreground tracking-tight">
            Stack
          </h2>
          <div class="mt-3 h-px w-10 bg-primary"></div>
        </div>

        <div class="divide-y divide-border">
          {siteConfig.technologies.map((tech) => (
            <div class="grid grid-cols-1 sm:grid-cols-[140px_1fr] gap-3 sm:gap-8 py-6 first:pt-0">
              <span class="font-mono text-xs uppercase tracking-widest text-muted-foreground pt-0.5">
                {tech.area}
              </span>
              <p class="text-sm text-muted-foreground leading-relaxed">
                {tech.list.join(" · ")}
              </p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
)}
