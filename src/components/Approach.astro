---
import { siteConfig } from "../config";
const hasApproach = siteConfig.approach && siteConfig.approach.length > 0;
---

{hasApproach && (
  <section id="approach" class="py-20 sm:py-24 px-8 sm:px-12 lg:px-24 border-b border-border">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-start">

        <div>
          <h2 class="font-display font-semibold text-2xl sm:text-3xl text-foreground tracking-tight">
            <span data-lang="en">How I work</span>
            <span data-lang="es">Cómo trabajo</span>
          </h2>
          <div class="mt-3 h-px w-10 bg-primary"></div>
        </div>

        <div class="divide-y divide-border">
          {siteConfig.approach.map((item, i) => {
            const esItem = siteConfig.es.approach[i];
            return (
              <div class="py-8 first:pt-0">
                <h3 class="font-display font-semibold text-lg text-foreground tracking-tight">
                  <span data-lang="en">{item.principle}</span>
                  <span data-lang="es">{esItem.principle}</span>
                </h3>
                <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
                  <span data-lang="en">{item.description}</span>
                  <span data-lang="es">{esItem.description}</span>
                </p>
              </div>
            );
          })}
        </div>

      </div>
    </div>
  </section>
)}
